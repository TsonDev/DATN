  m_Script: {fileID: 11500000, guid: e0cb3a07933f1c74b83479e339ea5f42, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogPanel: {fileID: 1771936695}
  nameText: {fileID: 608382811}
  dialogText: {fileID: 1133012801}
  npcImage: {fileID: 2028500333}
  npcSprite: {fileID: 21300000, guid: 7a3fe2c60ead1334a94d7eb425d7e74c, type: 3}
  npcName: "R\xF9a h\u01B0\u1EDBng d\u1EABn"
  dialogLines:
  - "Xin ch\xE0o!\nCh\xE0o m\u1EEBng b\u1EA1n \u0111\xE3 \u0111\u1EBFn v\u1EDBi GAME
    CITY HUB.\nCh\xFAc b\u1EA1n c\xF3 m\u1ED9t ng\xE0y m\u1EDBi vui v\u1EBB.\nH\xE3y
    l\xE0m theo h\u01B0\u1EDBng d\u1EABn c\u1EE7a t\xF4i."
  - "H\xE3y click v\xE0o ch\u1EEF \u201CCITY\u201D ph\xEDa tr\u01B0\u1EDBc c\xE1ch
    \u0111\xE2y kho\u1EA3ng 3 m\xE9t \u0111\u1EC3 tham gia v\xE0o th\xE0nh ph\u1ED1
    tr\xF2 ch\u01A1i.\n\u1EDE \u0111\xF3, b\u1EA1n s\u1EBD kh\xE1m ph\xE1 v\xF4 s\u1ED1
    ho\u1EA1t \u0111\u1ED9ng th\xFA v\u1ECB v\xE0 c\xE1c mini game \u0111\u1EA7y
    th\u1EED th\xE1ch \u2014 ch\u1EAFc ch\u1EAFn s\u1EBD khi\u1EBFn b\u1EA1n kh\xF4ng
    th\u1EC3 r\u1EDDi m\u1EAFt!"
  - "N\u1EBFu b\u1EA1n \u0111ang t\xECm m\u1ED9t n\u01A1i y\xEAn b\xECnh \u0111\u1EC3
    th\u01B0 gi\xE3n,\nh\xE3y \u0111i th\u1EB3ng \u0111\u1EBFn cu\u1ED1i con \u0111\u01B0\u1EDDng
    n\xE0y \u2014 n\u01A1i c\xF3 c\u0103n ph\xF2ng c\u1EE7a nh\u1EEFng ch\xFA m\xE8o
    si\xEAu d\u1EC5 th\u01B0\u01A1ng.\nTin t\xF4i \u0111i, b\u1EA1n s\u1EBD ch\u1EB3ng
    mu\u1ED1n r\u1EDDi kh\u1ECFi \u0111\xF3 \u0111\xE2u!"
  - "\u1EDE \u0111\xE2y kh\xF4ng c\xF3 nh\u1EA1c n\u1EC1n \u0111\xE2u nha~\nNh\u01B0ng
    \u0111\u1EEBng lo! Ngay c\u1EA1nh t\xF4i c\xF3 m\u1ED9t m\xE1y ph\xE1t nh\u1EA1c
    c\u1EF1c x\u1ECBn \u0111\xF3!\nB\u1EADt th\u1EED \u0111i \u2014 v\u1EEBa chill
    c\xF9ng c\u1EA3nh \u0111\u1EB9p, v\u1EEBa nghe nh\u1EA1c, c\u1EA3m gi\xE1c si\xEAu
    vui lu\xF4n~"
  - "L\u01B0u \xFD: M\xE1y nghe nh\u1EA1c s\u1EBD \u0111\u01B0\u1EE3c nghe ti\u1EBFp
    nh\u01B0ng khi out ra th\xEC ph\u1EA3i click 2 l\u1EA7n v\xE0o m\u1EDBi nghe
    ti\u1EBFp \u0111\u01B0\u1EE3c\nV\xE0 b\u1EA1n c\u0169ng c\xF3 th\u1EC3 nghe nh\u1EA1c
    b\u1EB1ng c\xE1ch \u1EA5n v\xE0o bi\u1EC3u t\u01B0\u1EE3ng n\u1ED9t nh\u1EA1c
    tr\xEAn g\xF3c ph\u1EA3i m\xE0n h\xECnh"
  delay: 0.3
